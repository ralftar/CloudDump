{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":disableDependencyDashboard"],
  "timezone": "Europe/Oslo",
  "schedule": ["before 9am every weekday"],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchDepNames": ["postgres"],
      "matchManagers": ["custom.regex"],
      "commitMessageTopic": "PostgreSQL client"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^Dockerfile$/"],
      "matchStrings": [
        "#\\s*renovate:\\s*datasource=(?<datasource>[^\\s]+)\\s+depName=(?<depName>[^\\s]+)\\s+versioning=(?<versioning>[^\\s]+)\\s*\\n\\s*postgresql-client-(?<currentValue>\\d+)\\s"
      ]
    }
  ]
}
